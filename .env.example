# Base URL da API usada no navegador (fetch no cliente).
# Deve ser a URL pública HTTPS (ex.: ...up.railway.app). Domínios .railway.internal
# não funcionam no browser — só entre serviços na mesma rede Railway.
NEXT_PUBLIC_API_URL=https://socializeserverbackend-production.up.railway.app

# Opcional: URL interna só para código server-side futuro (Route Handlers, etc.),
# por exemplo http://SEU_SERVICO.railway.internal:PORT — não expor como NEXT_PUBLIC_*.
